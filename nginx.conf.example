# /etc/nginx/sites-available/dns-tool
# 先用 HTTP 测试，HTTPS 后续用 acme.sh 补全

upstream dns_frontend {
    server 127.0.0.1:3000;
    keepalive 32;
}

# HTTP → 先直接提供服务用于测试
# 确认正常后改为 301 跳转 HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN;   # ← 改成你的域名

    # 访问日志
    access_log /var/log/nginx/dns-tool.access.log;
    error_log  /var/log/nginx/dns-tool.error.log;

    # 安全头
    add_header X-Content-Type-Options  nosniff;
    add_header X-Frame-Options         DENY;
    add_header X-XSS-Protection        "1; mode=block";
    add_header Referrer-Policy         "strict-origin-when-cross-origin";

    # 反代到 frontend 容器
    location / {
        proxy_pass         http://dns_frontend;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";

        proxy_connect_timeout  10s;
        proxy_send_timeout     120s;
        proxy_read_timeout     120s;

        # WebSocket 支持（备用）
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;
    }

    # 健康检查端点直接透传，不走缓存
    location = /health {
        proxy_pass http://dns_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        access_log off;
    }

    # 静态资源缓存（前端 JS/CSS 等）
    location ~* \.(js|css|png|ico|woff2?)$ {
        proxy_pass http://dns_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_cache_valid 200 1h;
        add_header Cache-Control "public, max-age=3600";
        expires 1h;
    }

    # 拒绝访问隐藏文件
    location ~ /\. {
        deny all;
    }
}

